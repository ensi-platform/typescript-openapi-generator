{
    "name": "@ensi-platform/typescript-openapi-generator",
    "license": "MIT",
    "version": "3.0.1",
    "description": "A swagger client generator for typescript",
    "type": "module",
    "private": false,
    "scripts": {
        "build": "rimraf dist && vite build",
        "init": "pnpm run build && node ./dist/bin/init.js",
        "generate": "pnpm run build && node ./dist/bin/generate.js",
        "prepublishOnly": "npm run build",
        "lint": "eslint . --ext .ts --fix",
        "format": "prettier ./src --write --ignore-path .prettierignore",
        "release": "node scripts/release.js",
        "release:dry-run": "pnpm run build && cd dist && npm publish --dry-run",
        "repack": "rimraf node_modules && pnpm store prune && pnpm install"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/ensi-platform/typescript-openapi-generator"
    },
    "engines": {
        "node": ">=16.0.0"
    },
    "bugs": "https://github.com/ensi-platform/typescript-openapi-generator/issues",
    "keywords": [
        "ensi",
        "front-end",
        "orval",
        "typescript",
        "openapi"
    ],
    "homepage": "https://github.com/ensi-platform/typescript-openapi-generator",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "/dist/*"
    ],
    "dependencies": {
        "@stoplight/yaml": "^4.3.0",
        "lodash.clonedeep": "^4.5.0",
        "openapi-typescript": "^6.7.6",
        "orval": "^8.8.0",
        "rimraf": "^6.1.3",
        "jiti": "^2.4.2",
        "yaml": "^2.8.3"
    },
    "devDependencies": {
        "@ensi-platform/typescript-openapi-generator": "link:.",
        "@rollup/plugin-commonjs": "^28.0.9",
        "@trivago/prettier-plugin-sort-imports": "^4.3.0",
        "@types/lodash.clonedeep": "^4.5.9",
        "@types/node": "^18.19.130",
        "@typescript-eslint/eslint-plugin": "^5.62.0",
        "@typescript-eslint/parser": "^5.62.0",
        "eslint": "^8.57.1",
        "eslint-config-airbnb": "^19.0.4",
        "eslint-config-prettier": "^8.10.2",
        "eslint-plugin-unicorn": "^47.0.0",
        "prettier": "^3.8.3",
        "rollup-plugin-peer-deps-external": "^2.2.4",
        "tslib": "^2.8.1",
        "typescript": "^6.0.3",
        "vite": "^6.4.2",
        "vite-plugin-dts": "^4.5.4",
        "vite-plugin-externalize-deps": "^0.10.0",
        "vite-plugin-static-copy": "^2.3.2"
    }
}
