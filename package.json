{
    "name": "@ensi-platform/typescript-openapi-generator",
    "license": "MIT",
    "version": "5.0.1",
    "description": "A swagger client generator for typescript",
    "type": "module",
    "private": false,
    "scripts": {
        "build": "rm -rf ./dist && vite build",
        "init": "pnpm run build && node ./dist/bin/init.js",
        "generate": "pnpm run build && node ./dist/bin/generate.js",
        "prepublishOnly": "pnpm run test && pnpm run build",
        "lint": "eslint . --fix",
        "format": "prettier ./src --write --ignore-path .prettierignore",
        "release": "node scripts/release.js",
        "release:dry-run": "pnpm run test && pnpm run build && cd dist && npm publish --dry-run",
        "repack": "rm -rf ./node_modules  && pnpm store prune && pnpm install",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/ensi-platform/typescript-openapi-generator"
    },
    "engines": {
        "node": ">=20.0.0"
    },
    "pnpm": {
        "packageExtensions": {
            "rolldown": {
                "optionalDependencies": {
                    "@rolldown/binding-darwin-arm64": "1.1.4",
                    "@rolldown/binding-darwin-x64": "1.1.4",
                    "@rolldown/binding-linux-arm64-gnu": "1.1.4",
                    "@rolldown/binding-linux-arm64-musl": "1.1.4",
                    "@rolldown/binding-linux-x64-gnu": "1.1.4",
                    "@rolldown/binding-linux-x64-musl": "1.1.4",
                    "@rolldown/binding-win32-arm64-msvc": "1.1.4",
                    "@rolldown/binding-win32-x64-msvc": "1.1.4"
                }
            }
        }
    },
    "bugs": "https://github.com/ensi-platform/typescript-openapi-generator/issues",
    "keywords": [
        "ensi",
        "front-end",
        "orval",
        "typescript",
        "openapi"
    ],
    "homepage": "https://github.com/ensi-platform/typescript-openapi-generator",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "/dist/*"
    ],
    "optionalDependencies": {
        "@rolldown/binding-darwin-arm64": "1.1.4",
        "@rolldown/binding-darwin-x64": "1.1.4",
        "@rolldown/binding-linux-arm64-gnu": "1.1.4",
        "@rolldown/binding-linux-arm64-musl": "1.1.4",
        "@rolldown/binding-linux-x64-gnu": "1.1.4",
        "@rolldown/binding-linux-x64-musl": "1.1.4",
        "@rolldown/binding-win32-arm64-msvc": "1.1.4",
        "@rolldown/binding-win32-x64-msvc": "1.1.4"
    },
    "dependencies": {
        "@stoplight/yaml": "^4.3.0",
        "jiti": "^2.7.0",
        "lodash.clonedeep": "^4.5.0",
        "openapi-typescript": "^7.13.0",
        "orval": "^8.20.0",
        "yaml": "^2.9.0"
    },
    "devDependencies": {
        "@ensi-platform/typescript-openapi-generator": "link:.",
        "@eslint/js": "^10.0.1",
        "@faker-js/faker": "^10.5.0",
        "@rollup/plugin-commonjs": "^29.0.3",
        "@trivago/prettier-plugin-sort-imports": "^6.0.2",
        "@types/lodash.clonedeep": "^4.5.9",
        "@types/node": "^22.19.0",
        "eslint": "^10.6.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-import-x": "^4.16.0",
        "eslint-plugin-unicorn": "^71.1.0",
        "globals": "^17.7.0",
        "msw": "^2.14.6",
        "prettier": "^3.9.4",
        "tslib": "^2.8.1",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.63.0",
        "vite": "^8.1.3",
        "vite-plugin-dts": "^5.0.3",
        "vite-plugin-static-copy": "^4.1.1",
        "vitest": "^4.1.10"
    }
}
